{
  "name": "@portfolio/shared",
  "version": "1.0.0",
  "description": "Shared types and utilities for portfolio frontend and backend",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./validators": {
      "import": "./dist/validators/index.js",
      "types": "./dist/validators/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "typescript",
    "types",
    "shared"
  ],
  "author": "Portfolio",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
