# ===========================================
# Portfolio UI - Environment Variables Example
# ===========================================
# Copy this file to .env.local for development

# API Configuration
# The URL of your backend API
VITE_API_URL=http://localhost:3000

# API version prefix (matches backend API_VERSION)
VITE_API_VERSION=v1

# WebSocket Configuration (for real-time features)
VITE_WS_URL=ws://localhost:3000

# App Configuration
VITE_APP_NAME=Portfolio
VITE_APP_DESCRIPTION=My Portfolio Website

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CODE_EXECUTION=true
VITE_ENABLE_COMMENTS=true

# Debug Mode (enables extra logging)
VITE_DEBUG=true
