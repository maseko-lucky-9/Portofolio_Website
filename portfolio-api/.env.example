# ===========================================
# Portfolio API - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
APP_NAME=Portfolio API
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# Admin Setup (first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# CORS (Vite dev server runs on port 8080)
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Portfolio <noreply@yourportfolio.com>

# Analytics
IPINFO_TOKEN=your-ipinfo-token
ENABLE_ANALYTICS=true

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Code Execution (Sandboxed)
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_TIMEOUT_MS=5000
CODE_EXECUTION_MEMORY_MB=128
CODE_EXECUTION_DOCKER_IMAGE=node:20-alpine

# External Services
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Cache TTL (seconds)
CACHE_TTL_PROJECTS=3600
CACHE_TTL_ARTICLES=3600
CACHE_TTL_ANALYTICS=300

# Feature Flags
ENABLE_WEBSOCKETS=true
ENABLE_CODE_EXECUTION=true
ENABLE_NEWSLETTER=true
DEMO_MODE=false

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
